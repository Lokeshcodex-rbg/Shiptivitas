+	border-left-color: #3182ce;
+	color: #90cdf4;
+}
+
+.Card-blue:hover {
+	border-left-color: #63b3ed;
+	background: linear-gradient(135deg, #2a4365 0%, #2c5282 100%);
 }
 
 .Card-green {
-  background-color: rgb(150, 190, 150);
-  color: white;
+	background: linear-gradient(135deg, #1c4532 0%, #22543d 100%);
+	border-left-color: #38a169;
+	color: #9ae6b4;
+}
+
+.Card-green:hover {
